{
  "name": "perspecta-workflow-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "npm run changelog && node esbuild.config.mjs",
    "dev": "npm run changelog && node esbuild.config.mjs --watch",
    "deploy": "npm run build && bash scripts/deploy-dev.sh",
    "changelog": "node scripts/gen-changelog.mjs",
    "changelog:check": "node scripts/gen-changelog.mjs --check",
    "test": "vitest run test",
    "test:watch": "vitest test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@perspecta/core": "*",
    "perspecta-ui": "file:./vendor/perspecta-ui",
    "@xyflow/svelte": "1.5.2",
    "svelte": "5.55.8"
  },
  "devDependencies": {
    "obsidian": "^1.13.0",
    "esbuild": "^0.25.0",
    "esbuild-svelte": "0.9.5",
    "svelte-preprocess": "6.0.3",
    "tslib": "^2.6.0"
  }
}
