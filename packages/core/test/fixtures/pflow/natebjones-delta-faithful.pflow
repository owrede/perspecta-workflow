{
  "pflowFormatVersion": 1,
  "workflow": {
    "name": "natebjones-delta",
    "description": "Incrementally update the 'NateBJones Prinzipien' research set: ingest new Substack posts and YouTube transcripts, run a delta analysis against the existing axiom/framework set, write a new update note, and propagate the changes into the core documents.",
    "args": {
      "type": "object",
      "properties": {
        "requested_period": { "type": "string" },
        "work_root": { "type": "string", "default": "Intelligence Impact/INIM-RESEARCH/INIM-RESEARCH Work/NateBJones Prinzipien" },
        "inbox_folder": { "type": "string", "default": "Intelligence Impact/INIM-RESEARCH/INIM-RESEARCH Work/NateBJones Prinzipien/_inbox" },
        "substack_archive": { "type": "string", "default": "https://natesnewsletter.substack.com/archive?sort=new" },
        "youtube_channel": { "type": "string", "default": "https://www.youtube.com/@NateBJones/videos" },
        "substack_tier": { "type": "string", "default": "substack-paid (175€/Jahr-Tier)" },
        "on_exists": { "type": "string", "default": "version" }
      },
      "required": []
    }
  },
  "nodes": [
    {
      "id": "in",
      "kind": "input",
      "label": "Requested period",
      "inputs": [],
      "outputs": [{ "id": "requested_period", "name": "requested_period", "schema": { "type": "string" } }],
      "phase": "Input"
    },
    {
      "id": "corpus",
      "kind": "agent",
      "label": "Read corpus state",
      "prompt": "Read the NEWEST update note in work_root (the highest `0X …` number — determine it live, do not hard-code). It sets the increment boundary. Extract: corpus_state_raw (the raw `korpus-stand` range string, verbatim), increment_from (the END date of that range — the new increment's lower bound, exclusive), last_run (the `zuletzt-gelaufen` of `_src/prompts/natebjones-delta-update.md`; if it differs from increment_from, use the LATER of the two), last_update_note (filename of the newest note), next_update_number (newest + 1). Also verify today's date from <env> (never the knowledge cutoff) — the increment's upper bound. Return all of these as the corpus state.",
      "inputs": [{ "id": "requested_period", "name": "requested_period", "schema": { "type": "string" } }],
      "outputs": [{ "id": "corpus_state", "name": "corpus_state", "schema": { "type": "string" } }],
      "phase": "Read"
    },
    {
      "id": "scope",
      "kind": "agent",
      "label": "Confirm scope",
      "prompt": "Clarify scope with the user ONLY if requested_period is empty. Ask (AskUserQuestion) three things: period (default: from increment_from / the later of increment_from and last_run, to today), sources (default: Substack + YouTube), substack login path (default: Playwright with the existing session). If requested_period was set, derive period_from/period_to from it and take defaults for the rest without asking. Return period_from, period_to, sources, and login_path.",
      "inputs": [
        { "id": "requested_period", "name": "requested_period", "schema": { "type": "string" } },
        { "id": "corpus_state", "name": "corpus_state", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "scope", "name": "scope", "schema": { "type": "string" } }],
      "phase": "Scope"
    },
    {
      "id": "precond",
      "kind": "loop",
      "label": "Preconditions",
      "prompt": "Verify the Substack paid session before fetching. Using Playwright (mcp__playwright__browser_*), open any paid post and check the full text appears. If the session is logged out (paid posts truncated / 'Subscribe to read'): have the user log in via a `! ` command — NEVER ask for tokens — then this step retries. On the FIRST line emit exactly `SESSION: ready` once the full text is visible, otherwise `SESSION: blocked` (the user login is still pending).",
      "inputs": [
        { "id": "scope", "name": "scope", "schema": { "type": "string" }, "required": true },
        { "id": "retry", "name": "retry", "schema": { "type": "string" } }
      ],
      "outputs": [{ "id": "session_ready", "name": "session_ready", "schema": { "type": "string" } }],
      "phase": "Preconditions",
      "config": { "maxPasses": 5, "sentinel": "SESSION:\\s*ready" }
    },
    {
      "id": "ss-fetch",
      "kind": "agent",
      "label": "Substack fetch",
      "prompt": "Fetch the Substack corpus — only NEW posts since increment_from (within the clarified period). Load the archive (substack_archive); after browser_navigate wait briefly then browser_evaluate WITHOUT clicks (the page re-navigates on interaction). Filter to Nate's own posts (a[href*=\"natesnewsletter.substack.com/p/\"]). Pull reliable dates from the footer 'recent posts' block of an opened post (format `MMM DD • NATE`), NOT the archive DOM (which has audio lengths like '46:36' that misparse as dates). For each new post pull the full text via `div.available-content`. Collect each post as { url, slug, title, date, body, paywalled_flag }.",
      "inputs": [{ "id": "session_ready", "name": "session_ready", "schema": { "type": "string" }, "required": true }],
      "outputs": [{ "id": "substack_posts", "name": "substack_posts", "schema": { "type": "string" } }],
      "phase": "Substack"
    },
    {
      "id": "ss-classify",
      "kind": "agent",
      "label": "Substack classify",
      "prompt": "Classify each post as full text or teaser (the paywall heuristic): full-text posts are ~15k–32k chars; Executive-Briefing teasers are ~2.5k–4.5k chars and end with 'Executive Circle members enjoy…' (the non-active AI Executive Circle tier). Set an `access` field per post: `full` (complete) or `teaser` (mark as [PAYWALL-TEASER]; the body may later be filled from the matching YouTube transcript). Return the posts with the access field. If all new posts are teasers or there are none, that is valid — the run continues with YouTube.",
      "inputs": [{ "id": "substack_posts", "name": "substack_posts", "schema": { "type": "string" }, "required": true }],
      "outputs": [{ "id": "substack_posts_classified", "name": "substack_posts_classified", "schema": { "type": "string" } }],
      "phase": "Substack"
    },
    {
      "id": "ss-inbox",
      "kind": "agent",
      "label": "Substack inbox",
      "prompt": "Write each classified post as its OWN raw file into inbox_folder, format EXACTLY like the existing `_inbox/` files (frontmatter quelle/titel/autor/datum/zugriff/abgerufen/tags, then `# title` and body). Append ` — NUR TEASER, Volltext im AI Executive Circle Tier` to `zugriff` when access is teaser, and mark a teaser body as [PAYWALL-TEASER]. Collect the written paths — these are the provenance anchors the update note will wikilink, so filenames must match exactly. Return the substack_inbox_files paths.",
      "inputs": [{ "id": "substack_posts_classified", "name": "substack_posts_classified", "schema": { "type": "string" }, "required": true }],
      "outputs": [{ "id": "substack_inbox_files", "name": "substack_inbox_files", "schema": { "type": "string" } }],
      "phase": "Substack"
    },
    {
      "id": "yt-fetch",
      "kind": "agent",
      "label": "YouTube fetch",
      "prompt": "Fetch the YouTube corpus — BINDING USER RULE: always base each evaluation on the VIDEO TRANSCRIPT, not just the description. Open youtube_channel (dismiss the DE consent wall with 'Alle ablehnen' if shown). Read the video list from ytInitialData (richGridRenderer → lockupViewModel: contentId, title, metadata rows). The English original title is in videoDetails.title of the watch page. Keep only new videos vs increment_from. Get each transcript via the DOM panel (the timedtext API returns empty for ASR captions): open the watch page, click the transcript button, wait ~2s, read the EXPANDED engagement-panel text (filtering search-box, timestamps `^\\d+:\\d+$`, and `N Sekunden/Minuten` markers). Collect each as { id, title_en, date, views, transcript }.",
      "inputs": [{ "id": "session_ready", "name": "session_ready", "schema": { "type": "string" }, "required": true }],
      "outputs": [{ "id": "youtube_videos", "name": "youtube_videos", "schema": { "type": "string" } }],
      "phase": "YouTube"
    },
    {
      "id": "yt-map",
      "kind": "agent",
      "label": "YouTube map",
      "prompt": "Map each video to one of three categories by comparing with the Substack posts: post-pendant (a video version of a same-named post → 1:1 pair in video_post_map), standalone (no post pendant → extra content from the transcript), or paywall-filler (a video whose post is access: teaser → its transcript fills the missing full text). This three-way split steers the next step: pendants and standalones go into the collected YouTube inbox file; paywall-filler transcripts are additionally appended to the matching teaser inbox file. Return video_post_map, standalone_videos, and paywall_fillers.",
      "inputs": [
        { "id": "youtube_videos", "name": "youtube_videos", "schema": { "type": "string" }, "required": true },
        { "id": "substack_posts_classified", "name": "substack_posts_classified", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "youtube_mapping", "name": "youtube_mapping", "schema": { "type": "string" } }],
      "phase": "YouTube"
    },
    {
      "id": "yt-inbox",
      "kind": "agent",
      "label": "YouTube inbox",
      "prompt": "Save the YouTube findings as ONE collected inbox file plus targeted appends. Write `YYYY-MM-DD–DD YouTube-Korpus ….md` into inbox_folder containing: the video↔post mapping table, standalone extra content, and the paywall-fill list. Frontmatter like the Substack inbox files; quelle = channel URL. Additionally append paywall-filling video transcripts to the matching teaser inbox file in substack_inbox_files (under a `## Volltext aus YouTube-Transkript` heading) so the teaser counts as filled — this requires the Substack inbox files to already exist (that is why this step is wired after Substack inbox). Return youtube_inbox_file.",
      "inputs": [
        { "id": "youtube_mapping", "name": "youtube_mapping", "schema": { "type": "string" }, "required": true },
        { "id": "substack_inbox_files", "name": "substack_inbox_files", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "youtube_inbox_file", "name": "youtube_inbox_file", "schema": { "type": "string" } }],
      "phase": "YouTube"
    },
    {
      "id": "existing",
      "kind": "agent",
      "label": "Read existing set",
      "prompt": "Read the FULL existing set so numbering continues without gaps. From `01 Mindset-Axiome.md` (plus the additions in the update notes): all axioms A1…An — note the highest number. From `06 Beratungs-Frameworks.md` plus the framework registers of the update notes: all frameworks F1…Fn — note the highest number. From the newest update note: the open research gaps / observation points (some mature into axioms over runs). Return axioms, frameworks, and gap_notes — the reference every new contribution is checked against.",
      "inputs": [{ "id": "corpus_state", "name": "corpus_state", "schema": { "type": "string" }, "required": true }],
      "outputs": [{ "id": "existing_set", "name": "existing_set", "schema": { "type": "string" } }],
      "phase": "Existing"
    },
    {
      "id": "delta",
      "kind": "synthesize",
      "label": "Delta analysis",
      "prompt": "Delta analysis — the analytical core. Check each new contribution (post full text AND its transcript) against the existing set. Classify per contribution: new axiom? (only if a core conviction recurs across sources and is not covered by the existing axioms → A{n+1}); refinement? (the common case — an existing axiom gets a supplementary paragraph with a new quote/anchor → note `→ Wirkt auf [[01 Mindset-Axiome#A{n}]]`); new framework? (a diagnosis schema / workshop skeleton / matrix → F{n+1}); observation point? (not yet mature → research gaps). Then: form 2–3 thematic arcs and name them; quote verbatim with source + date (provenance per claim); prepare an impact table (which core docs — 01, 06, 00 INDEX, optionally 02–05/07 — get what, with status; mark unchanged docs 'offen (optional)'). Return new_axioms, refinements, new_frameworks, observation_points, thematic_arcs, and the impact_table.",
      "inputs": [
        { "id": "substack_inbox_files", "name": "substack_inbox_files", "schema": { "type": "string" }, "required": true },
        { "id": "youtube_inbox_file", "name": "youtube_inbox_file", "schema": { "type": "string" }, "required": true },
        { "id": "existing_set", "name": "existing_set", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "delta", "name": "delta", "schema": { "type": "string" } }],
      "phase": "Delta"
    },
    {
      "id": "format",
      "kind": "agent",
      "label": "Format update",
      "prompt": "Render the new update note in the style of `09 / 10 / 11 Update … — Delta-Auswertung`. Set update_filename to `{{next_update_number}} Update {{today}} — Delta-Auswertung.md`. Advance the increment boundary: set the new `korpus-stand` to `\"{{increment_from}} bis {{today}}\"` — the range THIS run covered (never a single date, or the next run loses its start bound). Fill the template (frontmatter with tags/status/erstellt/parent/korpus-stand/zugriffsstand/quelle-roh; an intro blockquote citing the previous note and corpus state; then sections: TL;DR delta, Neuzugänge table, Thematische Bögen, Neue Axiome, Verfeinerungen, Neue Frameworks, Wirkungstabelle, Forschungslücken, Quellen). Output ONLY the rendered note as the formatted body.",
      "inputs": [
        { "id": "corpus_state", "name": "corpus_state", "schema": { "type": "string" }, "required": true },
        { "id": "delta", "name": "delta", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "formatted", "name": "formatted", "schema": { "type": "string" } }],
      "phase": "Format"
    },
    {
      "id": "save",
      "kind": "agent",
      "label": "Save update",
      "prompt": "Save the rendered update note via write_note. Write the formatted body to work_root, named by update_filename (`{{next_update_number}} Update {{today}} — Delta-Auswertung.md`). Honour on_exists if the target exists. Return the final written path as saved_path.",
      "inputs": [
        { "id": "formatted", "name": "formatted", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "saved_path", "name": "saved_path", "schema": { "type": "string" } }],
      "phase": "Save"
    },
    {
      "id": "propagate",
      "kind": "loop",
      "label": "Propagate docs",
      "prompt": "Propagate the changes into the existing core documents — ONE impact_table row per pass, until all are done. Per row, update the addressed document: `01 Mindset-Axiome` (new axioms as `## A{n}` sections after the last; refinements as supplementary paragraphs in the relevant axiom; extend cluster cross-links); `06 Beratungs-Frameworks` (new frameworks as register entries under a `## Erweiterung {{today}}` block; advance the overview table); `00 INDEX` (frontmatter aktualisiert/korpus-stand, update-hint blockquote linking saved_path, doc list, axiom clusters, framework quick-access table, corpus scope); other docs (02–05, 07) only if the row requires it, else status 'offen (optional)'. Set each row's status in the impact table to `erledigt` or `offen-optional`. On the FIRST line emit `ALL_ROWS_DONE: yes` when every row is erledigt or offen-optional, otherwise `ALL_ROWS_DONE: no` and proceed to the next row. The loop is bounded: one row per pass, a fixed count from the delta analysis.",
      "inputs": [
        { "id": "delta", "name": "delta", "schema": { "type": "string" }, "required": true },
        { "id": "saved_path", "name": "saved_path", "schema": { "type": "string" }, "required": true },
        { "id": "retry", "name": "retry", "schema": { "type": "string" } }
      ],
      "outputs": [{ "id": "impact_done", "name": "impact_done", "schema": { "type": "string" } }],
      "phase": "Propagate",
      "config": { "maxPasses": 12, "sentinel": "ALL_ROWS_DONE:\\s*yes" }
    },
    {
      "id": "cleanup",
      "kind": "agent",
      "label": "Cleanup",
      "prompt": "Finish & hygiene. MANDATORY increment markers (or the next run evaluates wrong): set `zuletzt-gelaufen` in `_src/prompts/natebjones-delta-update.md` to today (the next default run reads it as the 'since last run' lower bound); consistency-check that `zuletzt-gelaufen` (= today) matches the end date of the new `korpus-stand` — both should point to the same state. Hygiene: delete all scratch files (`post-*.txt`, `yt-*.txt`, temp scripts) in the vault root (do NOT touch `.playwright-mcp/`); verify the update note's wikilinks match the real `_inbox/` filenames exactly; if Substack/YouTube DOM selectors changed, fix them in the template AND in the fetch steps of this workflow. Return cleanup_done = ok.",
      "inputs": [
        { "id": "impact_done", "name": "impact_done", "schema": { "type": "string" }, "required": true },
        { "id": "saved_path", "name": "saved_path", "schema": { "type": "string" }, "required": true }
      ],
      "outputs": [{ "id": "cleanup_done", "name": "cleanup_done", "schema": { "type": "string" } }],
      "phase": "Cleanup"
    },
    {
      "id": "end",
      "kind": "output",
      "label": "Done",
      "inputs": [{ "id": "cleanup_done", "name": "cleanup_done", "schema": { "type": "string" }, "required": true }],
      "outputs": [],
      "phase": "Done"
    }
  ],
  "wires": [
    { "from": { "nodeId": "in", "portId": "requested_period" }, "to": { "nodeId": "corpus", "portId": "requested_period" } },
    { "from": { "nodeId": "in", "portId": "requested_period" }, "to": { "nodeId": "scope", "portId": "requested_period" } },
    { "from": { "nodeId": "corpus", "portId": "corpus_state" }, "to": { "nodeId": "scope", "portId": "corpus_state" } },
    { "from": { "nodeId": "scope", "portId": "scope" }, "to": { "nodeId": "precond", "portId": "scope" } },
    { "from": { "nodeId": "precond", "portId": "session_ready" }, "to": { "nodeId": "precond", "portId": "retry" } },

    { "from": { "nodeId": "precond", "portId": "session_ready" }, "to": { "nodeId": "ss-fetch", "portId": "session_ready" } },
    { "from": { "nodeId": "ss-fetch", "portId": "substack_posts" }, "to": { "nodeId": "ss-classify", "portId": "substack_posts" } },
    { "from": { "nodeId": "ss-classify", "portId": "substack_posts_classified" }, "to": { "nodeId": "ss-inbox", "portId": "substack_posts_classified" } },

    { "from": { "nodeId": "precond", "portId": "session_ready" }, "to": { "nodeId": "yt-fetch", "portId": "session_ready" } },
    { "from": { "nodeId": "yt-fetch", "portId": "youtube_videos" }, "to": { "nodeId": "yt-map", "portId": "youtube_videos" } },
    { "from": { "nodeId": "ss-classify", "portId": "substack_posts_classified" }, "to": { "nodeId": "yt-map", "portId": "substack_posts_classified" } },
    { "from": { "nodeId": "yt-map", "portId": "youtube_mapping" }, "to": { "nodeId": "yt-inbox", "portId": "youtube_mapping" } },
    { "from": { "nodeId": "ss-inbox", "portId": "substack_inbox_files" }, "to": { "nodeId": "yt-inbox", "portId": "substack_inbox_files" } },

    { "from": { "nodeId": "corpus", "portId": "corpus_state" }, "to": { "nodeId": "existing", "portId": "corpus_state" } },

    { "from": { "nodeId": "ss-inbox", "portId": "substack_inbox_files" }, "to": { "nodeId": "delta", "portId": "substack_inbox_files" } },
    { "from": { "nodeId": "yt-inbox", "portId": "youtube_inbox_file" }, "to": { "nodeId": "delta", "portId": "youtube_inbox_file" } },
    { "from": { "nodeId": "existing", "portId": "existing_set" }, "to": { "nodeId": "delta", "portId": "existing_set" } },

    { "from": { "nodeId": "corpus", "portId": "corpus_state" }, "to": { "nodeId": "format", "portId": "corpus_state" } },
    { "from": { "nodeId": "delta", "portId": "delta" }, "to": { "nodeId": "format", "portId": "delta" } },
    { "from": { "nodeId": "format", "portId": "formatted" }, "to": { "nodeId": "save", "portId": "formatted" } },

    { "from": { "nodeId": "delta", "portId": "delta" }, "to": { "nodeId": "propagate", "portId": "delta" } },
    { "from": { "nodeId": "save", "portId": "saved_path" }, "to": { "nodeId": "propagate", "portId": "saved_path" } },
    { "from": { "nodeId": "propagate", "portId": "impact_done" }, "to": { "nodeId": "propagate", "portId": "retry" } },

    { "from": { "nodeId": "propagate", "portId": "impact_done" }, "to": { "nodeId": "cleanup", "portId": "impact_done" } },
    { "from": { "nodeId": "save", "portId": "saved_path" }, "to": { "nodeId": "cleanup", "portId": "saved_path" } },
    { "from": { "nodeId": "cleanup", "portId": "cleanup_done" }, "to": { "nodeId": "end", "portId": "cleanup_done" } }
  ]
}
